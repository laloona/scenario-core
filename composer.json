{
  "name": "stateforge/scenario-core",
  "description": "Core library for declarative, attribute-driven scenario orchestration for reproducible test data states in PHP.",
  "type": "library",
  "keywords": [
    "testing",
    "phpunit",
    "fixtures",
    "scenario",
    "state",
    "test-data"
  ],
  "license": "BSD-3-Clause",
  "authors": [
    {
      "name": "Christina Koenig",
      "email": "christina.koenig@looriva.de",
      "role": "lead"
    }
  ],
  "homepage": "https://github.com/laloona/scenario-core",
  "support": {
    "issues": "https://github.com/laloona/scenario-core/issues",
    "source": "https://github.com/laloona/scenario-core"
  },
  "require": {
    "php": ">=8.2",
    "ext-dom": "*",
    "phpunit/phpunit": "^11.0 || ^12.0 || ^13.0"
  },
  "bin": [
    "bin/scenario"
  ],
  "autoload": {
    "psr-4": {
      "Stateforge\\Scenario\\Core\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Stateforge\\Scenario\\Core\\Tests\\Unit\\": "tests/unit/"
    },
    "classmap": [
      "tests/files"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.60",
    "phpstan/phpstan-strict-rules": "^2.0"
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.1-dev"
    }
  }
}
